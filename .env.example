# Copy this file to .env and fill in your values
# cp .env.example .env

# PostgreSQL
POSTGRES_USER=app
POSTGRES_PASSWORD=changeme
POSTGRES_DB=appdb

# App port exposed on the host (default: 80)
APP_PORT=80

# Session secret for the Express API (use a long random string in production)
SESSION_SECRET=change-this-to-a-long-random-string
